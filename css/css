/* Class dùng để ẩn phần tử */
.hidden {
  display: none;
}
/* Trạng thái mặc định trên mobile có thể là ẩn menu hoặc thu gọn */
.main-menu {
  /* Các thuộc tính CSS sẵn có của bạn */
}

/* Khi menu có thêm class .active thì sẽ hiển thị ra */
.main-menu.active {
  display: block; /* Hoặc các thuộc tính định dạng hiển thị menu của bạn */
}
/* Giao diện Nền tối */
body.dark-mode {
  background-color: #111827;
  color: #f8fafc;
}

/* Giao diện Nền ấm (màu ngả vàng dịu mắt) */
body.warm-mode {
  background-color: #fff7ed;
  color: #431407;
}
